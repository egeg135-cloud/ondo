# Supabase 연결 정보 — 이 파일을 복사해 .env 로 만들고 값을 채워주세요.
# (.env 는 .gitignore 에 포함되어 커밋되지 않습니다.)

VITE_SUPABASE_URL=https://ivcqzmoaxmlrgcyjqkji.supabase.co

# anon key 는 Supabase 대시보드 → Settings → API → Project API keys → anon public 에서 복사
VITE_SUPABASE_ANON_KEY=여기에_anon_key_붙여넣기

# 운영자 대시보드(/admin) 접근용 키 — 아무 문자열이나 정해서 넣으세요
VITE_ADMIN_KEY=여기에_원하는_관리자키_입력
